<Window x:Class="LiveryInstaller.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LiveryInstaller.UI.Views"
        xmlns:vm="clr-namespace:LiveryInstaller.UI.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="800" d:DesignHeight="350"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        Title="PMDG - Livery Installer" Height="750" Width="1420"
        WindowStartupLocation="CenterScreen" Background="#1C1C1C">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Menu Grid.Column="0" Width="100" Margin="2">
            <Menu.Resources>
                <Style TargetType="{x:Type MenuItem}">
                    <Style.Setters>
                        <Setter Property="Width" Value="95" />
                    </Style.Setters>
                </Style>
            </Menu.Resources>
            <MenuItem Header="Liveries" Command="{Binding NavigateToLiveriesPageCommand}"
                      IsEnabled="{Binding IsLiveryPageEnabled}"
                      ToolTip="You must first specify the liveries directory in the application settings"
                      ToolTipService.ShowOnDisabled="True" />
            <MenuItem Header="Import" Command="{Binding NavigateToLiveryImportPageCommand}"
                      IsEnabled="{Binding IsLiveryPageEnabled}"
                      ToolTip="You must first specify the liveries directory in the application settings"
                      ToolTipService.ShowOnDisabled="True" />
            <MenuItem Header="Settings" Command="{Binding NavigateToSettingsPageCommand}" />
        </Menu>
        <Border Grid.Column="1" CornerRadius="8" Background="#202020">
            <ContentControl Content="{Binding Path=CurrentPage}" />
        </Border>
    </Grid>
</Window>