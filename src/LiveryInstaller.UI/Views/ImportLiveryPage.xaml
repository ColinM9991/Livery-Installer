<UserControl x:Class="LiveryInstaller.UI.Views.ImportLiveryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:LiveryInstaller.UI.ViewModels"
             xmlns:uc="clr-namespace:LiveryInstaller.UI.UserControls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ImportLiveryPageViewModel}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style TargetType="{x:Type uc:InfoField}">
            <Setter Property="Margin" Value="0, 24, 0, 0" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="16,24,16,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0">
            <TextBlock Text="Import Livery" Style="{StaticResource PageHeading}" />
            <uc:InputControl Title="PTP File" Description="Select the package to import" Icon="📂">
                <uc:InputControl.CardContent>
                    <uc:FilePickerControl Path="{Binding LiveryFile, Mode=TwoWay}" Filter="PTP Package|*.ptp"
                                          Type="File" />
                </uc:InputControl.CardContent>
            </uc:InputControl>
            <uc:InputControl Title="Custom Icon" Description="Use a custom icon" Icon="🖼️">
                <uc:InputControl.CardContent>
                    <CheckBox IsChecked="{Binding UseCustomIcon}" />
                </uc:InputControl.CardContent>
            </uc:InputControl>
            <uc:InputControl Title="Icon File" Description="Select the icon to use" Icon="📂"
                             Visibility="{Binding UseCustomIcon, Converter={StaticResource BooleanToVisibility}}">
                <uc:InputControl.CardContent>
                    <uc:FilePickerControl Path="{Binding IconFile, Mode=TwoWay}" Filter="Icons|*.jpg;*.png"
                                          Type="File" />
                </uc:InputControl.CardContent>
            </uc:InputControl>

            <Button Content="Import" Command="{Binding ImportCommand}" HorizontalAlignment="Right"
                    Margin="0, 0, 0, 0" />
        </StackPanel>
        <uc:Card Grid.Column="2" Title="Preview">
            <uc:Card.CardContent>
                <Grid>
                    
                    <TextBlock Text="Livery installed successfully" FontSize="24" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding WasImportSuccessful, Converter={StaticResource BooleanToVisibility}}"/>
                    
                    <StackPanel Margin="16,0,16, 0"
                                Visibility="{Binding IsLoaded, Converter={StaticResource BooleanToVisibility}}">

                        <Image Source="{Binding Icon}"
                               Stretch="Uniform"
                               Width="256"
                               Height="128"
                               RenderOptions.BitmapScalingMode="LowQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top" />

                        <uc:InfoField Title="Livery" Text="{Binding LoadedLivery.Livery.Name}" />

                        <uc:InfoField Title="Aircraft" Text="{Binding LoadedLivery.AircraftType}" />

                        <uc:InfoField Title="Manufacturer" Text="{Binding LoadedLivery.Manufacturer}" />

                        <Border Margin="0,18,0,0"
                                Padding="14"
                                Background="#202020"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Description"
                                           Foreground="#9CA3AF"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <ScrollViewer MaxHeight="160"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock
                                        Text="{Binding LoadedLivery.Livery.Description, Converter={StaticResource EscapedNewLineConverter}}"
                                        Margin="0,8,0,0"
                                        FontSize="13"
                                        Foreground="#E5E7EB"
                                        LineHeight="20"
                                        TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </uc:Card.CardContent>
        </uc:Card>
    </Grid>
</UserControl>