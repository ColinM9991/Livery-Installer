<UserControl x:Class="LiveryInstaller.UI.UserControls.InputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="#2D2D2D" CornerRadius="8" Padding="16" Margin="0,0,0,25">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="36" Height="36"
                    Background="#3D3D3D" CornerRadius="4" Margin="0,0,12,0">
                <TextBlock Text="{Binding Icon, ElementName=Root}"
                           Foreground="#FFFFFF" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           FontSize="14" Foreground="#FFFFFF" />
                <TextBlock Text="{Binding Description, ElementName=Root}"
                           FontSize="12" Foreground="#9D9D9D" />
            </StackPanel>
            <ContentPresenter Grid.Column="2"
                              Content="{Binding CardContent, ElementName=Root}" />
        </Grid>
    </Border>
</UserControl>