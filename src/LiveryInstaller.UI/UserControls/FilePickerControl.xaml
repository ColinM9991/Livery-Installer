<UserControl x:Class="LiveryInstaller.UI.UserControls.FilePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:userControls="clr-namespace:LiveryInstaller.UI.UserControls"
             x:Name="Self"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=userControls:FilePickerControl, IsDesignTimeCreatable=False}"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <TextBox Text="{Binding Path, ElementName=Self}" VerticalAlignment="Center" IsTabStop="False" PreviewMouseLeftButtonDown="UIElement_OnMouseDown" />
    </Grid>
</UserControl>
