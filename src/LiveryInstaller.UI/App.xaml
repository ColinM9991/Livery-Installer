<Application x:Class="LiveryInstaller.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LiveryInstaller.UI.ViewModels"
             xmlns:views="clr-namespace:LiveryInstaller.UI.Views"
             xmlns:local="clr-namespace:LiveryInstaller.UI"
             xmlns:services="clr-namespace:LiveryInstaller.UI.Services">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
            <services:EscapedNewLineConverter x:Key="EscapedNewLineConverter"/>
            <DataTemplate DataType="{x:Type vm:LiveryPageViewModel}">
                <views:LiveryPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsPageViewModel}">
                <views:SettingsPage />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ImportLiveryPageViewModel}">
                <views:ImportLiveryPage />
            </DataTemplate>
            <Style x:Key="PageHeading" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
            </Style>
            <Style x:Key="SubHeading" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <Setter Property="Margin" Value="0,12,0, 12"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>